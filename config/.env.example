# ─────────────────────────────────────────────────────────────────
# docker-osint-stack — environment template
# Copy to ./config/.env and fill in. NEVER commit the populated file.
# ─────────────────────────────────────────────────────────────────

# Postgres audit-log
POSTGRES_USER=osint
POSTGRES_PASSWORD=change_me_before_first_boot
POSTGRES_DB=osint_audit

# SpiderFoot internal port (host port is bound only via Nginx)
SPIDERFOOT_PORT=5001

# Nginx host bind. Default is 127.0.0.1 — the stack should NOT be
# exposed on a public interface without basic-auth + TLS in front.
NGINX_HOST_BIND=127.0.0.1
NGINX_HOST_PORT=8080

# Encryption passphrase for `scripts/export_findings.sh`. The script
# refuses to run if this is empty.
EXPORT_GPG_PASSPHRASE=

# Investigation tag — copied into every audit-log row for the session.
# E.g. "ACME-2026Q2-engagement-042"
SESSION_TAG=
